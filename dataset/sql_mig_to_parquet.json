{
	"name": "sql_mig_to_parquet",
	"properties": {
		"linkedServiceName": {
			"referenceName": "AzureDataLakeStorage7",
			"type": "LinkedServiceReference"
		},
		"parameters": {
			"TableName": {
				"type": "string"
			}
		},
		"annotations": [],
		"type": "Parquet",
		"typeProperties": {
			"location": {
				"type": "AzureBlobFSLocation",
				"fileName": {
					"value": "@concat(dataset().TableName,'_',formatDateTime(utcNow(),'yyyyMMddHHmmss'),'.parquet')",
					"type": "Expression"
				},
				"folderPath": {
					"value": "@concat(dataset().TableName,'-',formatDateTime(utcnow(),'yyyyMMdd'))",
					"type": "Expression"
				},
				"fileSystem": "gsretail"
			},
			"compressionCodec": "snappy"
		},
		"schema": []
	}
}